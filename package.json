{
  "name": "ubt-runner",
  "displayName": "UBT-Runner",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ubt-runner.RunUBT",
        "title": "Run UBT"
      },
      {
        "command": "ubt-runner.TestRun",
        "title": "Compile",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ubt-runner.TestRun",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "UBT Runner",
      "properties": {
        "ubt-runner.unrealEngineInstallation": {
          "type": "string",
          "default": "",
          "description": "The installation path of Unreal Engine."
        },
        "ubt-runner.openProjectAfterBuild": {
          "type": "boolean",
          "default": false,
          "description": "Automaticaly load project after build ends."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}